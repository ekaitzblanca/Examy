<Page x:Class="SimulacroOposiciones.MVC.PracticeResume.View"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SimulacroOposiciones.MVC.PracticeResume"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1000"
      Title="Examy"
      Background="#F4F8FB">

    <Page.Resources>

        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="BorderBrush" Value="#D6E4F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style x:Key="StatTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="34"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="60"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F4C81"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C7D9EA"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8FBFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EEF6FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BackButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="54"/>
            <Setter Property="FontSize" Value="17"/>
        </Style>

    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Grid.Row="0"
                Background="#0F4C81"
                CornerRadius="18"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <TextBlock
                    x:Name="lbl_version"
                    Text="Versión 1.0.0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#DCEBFA"/>

                <StackPanel>
                    <TextBlock Text="Examy"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Resumen del test"
                               FontSize="14"
                               Foreground="#DCEBFA"
                               Margin="0,4,0,0"/>

                    <TextBlock Text="Consulta tu resultado final"
                               FontSize="12"
                               Foreground="#BFD9F5"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- MENSAJE -->
                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="✅ Test completado"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="lbl_summaryMessage"
                                   Text="Buen trabajo. Aquí tienes el resumen de tu resultado."
                                   FontSize="15"
                                   Foreground="#6B7280"
                                   Margin="0,10,0,0"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ESTADÍSTICAS -->
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SummaryCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Aciertos" Style="{StaticResource StatTitleStyle}"/>
                            <TextBlock x:Name="lbl_correctCount" Text="14" Style="{StaticResource StatValueStyle}" Foreground="#15803D"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource SummaryCardStyle}" Margin="6,0">
                        <StackPanel>
                            <TextBlock Text="Fallos" Style="{StaticResource StatTitleStyle}"/>
                            <TextBlock x:Name="lbl_wrongCount" Text="6" Style="{StaticResource StatValueStyle}" Foreground="#DC2626"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource SummaryCardStyle}" Margin="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Total" Style="{StaticResource StatTitleStyle}"/>
                            <TextBlock x:Name="lbl_totalCount" Text="20" Style="{StaticResource StatValueStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- PORCENTAJE (SIN TOCAR) -->
                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Porcentaje de acierto"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7280"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="lbl_percentage"
                                   Text="70%"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="#0F4C81"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>

                        <ProgressBar x:Name="progress_score"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="70"
                                     Height="16"
                                     Margin="0,18,0,0"
                                     Foreground="#0F4C81"
                                     Background="#E5EEF7"/>
                    </StackPanel>
                </Border>

                <!-- ANÁLISIS -->
                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel>
                        <TextBlock Text="📊 Análisis del resultado"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="lbl_resultFeedback"
                                   Text="Vas bien, pero puedes mejorar."
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   Margin="0,10,0,5"/>

                        <TextBlock x:Name="lbl_resultAnalysis"
                                   Text="Revisa tus errores para mejorar el resultado."
                                   FontSize="13"
                                   Foreground="#6B7280"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- BOTONES FULL WIDTH -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="btn_Review"
                    Content="🔍 Revisar test"
                    Style="{StaticResource SecondaryButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,5,0"/>

            <Button x:Name="btn_Back"
                    Content="← Volver al menú"
                    Style="{StaticResource BackButtonStyle}"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    Margin="5,0,0,0"/>
        </Grid>

        <!-- FOOTER -->
        <TextBlock Grid.Row="3"
                   Text="Desarrollado por Ekaitz Blanca"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,0"
                   FontSize="12"
                   Foreground="#9CA3AF"/>
    </Grid>
</Page>