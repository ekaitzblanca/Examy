<Page x:Class="SimulacroOposiciones.MVC.StartMenu.View"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SimulacroOposiciones.MVC.StartMenu"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="White"
      Title="View">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="147*"/>
            <RowDefinition Height="154*"/>
            <RowDefinition Height="149*"/>
        </Grid.RowDefinitions>
        <Button x:Name="btn_auxiliar" Content="Auxiliar de Enfermeria" Margin="10,10,10,12"/>
        <Button x:Name="btn_laboratorio" Content="Tecnico de Laboratorio" Margin="10,15,10,13" Grid.Row="1"/>
        <Button x:Name="btn_celador" Content="Celador" Margin="10,14,10,10" Grid.Row="2"/>
    </Grid>
</Page>
