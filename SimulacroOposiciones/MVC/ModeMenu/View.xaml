      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SimulacroOposiciones.MVC.ModeMenu"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="White"
      Title="View">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="148*"/>
            <RowDefinition Height="153*"/>
            <RowDefinition Height="149*"/>
        </Grid.RowDefinitions>
        <Button x:Name="btn_Practica" Content="Test de Practica" Margin="10,10,10,15"/>
        <Button x:Name="btn_Errores" Content="Test de Errores" Margin="10,11,10,19" Grid.Row="1"/>
        <Button x:Name="btn_Examen" Content="Simulacro Examen" Margin="10,16,10,10" Grid.Row="2"/>

    </Grid>
</Page>
