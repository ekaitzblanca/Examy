<Page x:Class="SimulacroOposiciones.MVC.ModeMenu.View"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SimulacroOposiciones.MVC.ModeMenu"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Examy"
      Background="#F4F8FB">

    <Page.Resources>
        <Style x:Key="ModeButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="110"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D6E4F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="75"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="56"
                                        Height="56"
                                        CornerRadius="28"
                                        Background="#E8F1FB"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                    <TextBlock x:Name="icon"
                                               Text="📝"
                                               FontSize="26"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Margin="16,0,0,0">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               FontSize="{TemplateBinding FontSize}"
                                               FontWeight="{TemplateBinding FontWeight}"
                                               Foreground="{TemplateBinding Foreground}"/>
                                    <TextBlock x:Name="description"
                                               Text="Selecciona este modo para empezar"
                                               FontSize="13"
                                               Foreground="#6B7280"
                                               Margin="0,6,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="›"
                                           FontSize="28"
                                           Foreground="#3B82F6"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F9FCFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EAF4FF"/>
                            </Trigger>

                            <Trigger Property="Tag" Value="practica">
                                <Setter TargetName="icon" Property="Text" Value="📘"/>
                                <Setter TargetName="description" Property="Text" Value="Practica preguntas a tu ritmo"/>
                            </Trigger>

                            <Trigger Property="Tag" Value="errores">
                                <Setter TargetName="icon" Property="Text" Value="🔁"/>
                                <Setter TargetName="description" Property="Text" Value="Repasa las preguntas que has fallado"/>
                            </Trigger>

                            <Trigger Property="Tag" Value="examen">
                                <Setter TargetName="icon" Property="Text" Value="🧠"/>
                                <Setter TargetName="description" Property="Text" Value="Haz un simulacro como si fuera el examen real"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="54"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F4C81"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C7D9EA"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                Padding="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8FBFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EEF6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CABECERA COMPACTA -->
        <Border Grid.Row="0"
                Background="#0F4C81"
                CornerRadius="18"
                Padding="20"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Examy"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Selecciona el modo de test"
                           FontSize="14"
                           Foreground="#DCEBFA"
                           Margin="0,4,0,0"/>

                <TextBlock Text="Elige cómo quieres practicar hoy"
                           FontSize="12"
                           Foreground="#BFD9F5"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- BOTONES -->
        <StackPanel Grid.Row="1">
            <Button x:Name="btn_Practica"
                    Tag="practica"
                    Content="Test de Práctica"
                    Style="{StaticResource ModeButtonStyle}"/>

            <Button x:Name="btn_Errores"
                    Tag="errores"
                    Content="Test de Errores"
                    Style="{StaticResource ModeButtonStyle}"/>

            <Button x:Name="btn_Examen"
                    Tag="examen"
                    Content="Simulacro de Examen"
                    Style="{StaticResource ModeButtonStyle}"/>
        </StackPanel>

        <!-- BOTÓN VOLVER -->
        <Button x:Name="btn_Back"
                Grid.Row="2"
                Content="← Volver"
                Style="{StaticResource BackButtonStyle}"
                Margin="0,8,0,0"/>

        <!-- FOOTER -->
        <TextBlock Grid.Row="3"
                   Text="Desarrollado por Ekaitz Blanca"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,0"
                   FontSize="12"
                   Foreground="#9CA3AF"/>
    </Grid>
</Page>